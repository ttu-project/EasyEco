# Existing application settings
MONGO_URI=mongodb+srv://...
JWT_SECRET=replace-with-a-long-random-secret

# SMSPoh Verify API V3. Keep these values on the server only; never add them
# to the Expo application or commit the real values.
SMSPOH_API_KEY=your-smspoh-v3-api-key
SMSPOH_API_SECRET=your-smspoh-v3-api-secret
SMSPOH_SENDER_ID=EasyEco
SMSPOH_BRAND=EasyEco
# Keep this at 6 while the mobile app displays six OTP input boxes.
SMSPOH_OTP_TTL_SECONDS=120
SMSPOH_OTP_PIN_LENGTH=6

# Public base URL for image links in production. Omit this when running the
# backend locally; it will use the current server URL automatically.
PUBLIC_BASE_URL=https://your-api-domain.example
