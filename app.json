{
  "expo": {
    "name": "easyeco",
    "slug": "easyeco",
    "scheme": "com.anonymous.easyeco",
    "icon": "./assets/Logoact2.png",
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging"
    ],
    "android": {
      "package": "com.anonymous.easyeco",
      "usesCleartextTraffic": true,
      "googleServicesFile": "./android/app/google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": { "scheme": "fb1681691103048797" }
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logoact2.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "eas": {
        "projectId": "6c1baa2b-95cf-4fd4-a3ff-d9ac4b777bf3"
      }
    }
  }
}
