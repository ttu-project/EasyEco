{
  "expo": {
    "name": "easyeco",
    "slug": "easyeco",
    "scheme": "com.anonymous.easyeco",
    "icon": "./assets/Logoact2.png",
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging"
    ],
    "android": {
      "package": "com.anonymous.easyeco",
      "usesCleartextTraffic": true,
      "googleServicesFile": "./android/app/google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": {
            "scheme": "fb1681691103048797"
          }
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logoact2.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "eas": {
        "projectId": "83ed6c85-452f-496f-ab5d-f88870eb3183"
      }
    },
    "owner": "thandarhtetaung"
  }
}
